# scrm-platform-front 前台发布配置
# 复制为 config.env 并填写真实值（config.env 已加入 .gitignore）
# 前台为 pnpm monorepo，本地构建后 rsync 产物到服务器 public/ 下

# 生产服务器（与后台/框架同一服务器）
SERVER_HOST=social.dsplat.com
SERVER_USER=root
WEB_ROOT=/alidata/www/dsplat.com/social.dsplat.com

# 本地 pnpm 可执行文件（用于 install / build）
PNPM_BIN=pnpm

# ---- App 映射覆盖（可选，缺省用脚本内置默认）----
# 内置默认：
#   h5  : build:h5  -> apps/h5/dist/build/h5/         -> public/h5
#   ops : build:ops -> apps/ops-console/dist/build/h5/ -> public/console
# 如需覆盖，取消注释并修改：
# APP_H5_BUILD=build:h5
# APP_H5_DIST=apps/h5/dist/build/h5
# APP_H5_TARGET=public/h5
# APP_OPS_BUILD=build:ops
# APP_OPS_DIST=apps/ops-console/dist/build/h5
# APP_OPS_TARGET=public/console
